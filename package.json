{
  "name": "ascent-math",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node scripts/clean-next.mjs",
    "dev": "node scripts/dev.mjs",
    "dev:clean": "node scripts/dev.mjs --clean",
    "preview": "node scripts/kill-next.mjs && npm run build && next start --port 3000 --hostname 127.0.0.1",
    "build": "node scripts/kill-next.mjs && node scripts/clean-next.mjs && next build",
    "start": "next start",
    "lint": "eslint",
    "audit:validate": "npx tsx scripts/audit/validate-content.ts",
    "logo:generate": "python3 scripts/generate-favicons.py",
    "auth:setup": "node scripts/setup-firebase.mjs",
    "auth:production": "node scripts/setup-auth-production.mjs",
    "book:setup": "node scripts/setup-booking.mjs",
    "book:test": "node scripts/test-booking.mjs",
    "firebase:deploy": "firebase deploy",
    "firebase:deploy:hosting": "firebase deploy --only hosting",
    "firebase:deploy:rules": "firebase deploy --only firestore:rules",
    "firebase:emulators": "firebase emulators:start --only auth,firestore"
  },
  "dependencies": {
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^2.0.1",
    "firebase": "^12.13.0",
    "next": "^15.5.18",
    "react": "^19.1.7",
    "react-dom": "^19.1.7",
    "resend": "^6.12.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^15.5.18",
    "firebase-tools": "^14.27.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
