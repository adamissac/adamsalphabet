# ===========================================================================
# Ascent Math — environment variables
#
# Copy this file to `.env.local` and fill in the values. `.env.local` is
# git-ignored and is the file Next.js loads in development. For production
# (Vercel etc.), add the same keys via the dashboard.
# ===========================================================================

# ---------------------------------------------------------------------------
# Resend — booking email delivery
# ---------------------------------------------------------------------------
RESEND_API_KEY=

# ---------------------------------------------------------------------------
# Booking destination
# ---------------------------------------------------------------------------
BOOKING_RECIPIENT_EMAIL=adamissac08@gmail.com,alanmozhoor@gmail.com

# ---------------------------------------------------------------------------
# Sender identity
# ---------------------------------------------------------------------------
# Once you verify a custom domain in Resend, switch this to something like:
#   "Ascent Math <booking@adamsalphabet.com>"
BOOKING_FROM_EMAIL="Ascent Math <onboarding@resend.dev>"

# ---------------------------------------------------------------------------
# Upstash Redis — distributed rate limiting (production)
# ---------------------------------------------------------------------------
# Create a free database at https://console.upstash.com/
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---------------------------------------------------------------------------
# Cloudflare Turnstile — CAPTCHA on contact form
# ---------------------------------------------------------------------------
# Create a widget at https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ===========================================================================
# Firebase Authentication
# ===========================================================================
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Set to "false" to enable /login and /signup while testing Firebase locally.
NEXT_PUBLIC_AUTH_COMING_SOON=true
