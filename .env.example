# ===========================================================================
# Adam's Alphabet  - environment variables
#
# Copy this file to `.env.local` and fill in the values. `.env.local` is
# git-ignored and is the file Next.js loads in development. For production
# (Vercel etc.), add the same keys via the dashboard.
# ===========================================================================

# ---------------------------------------------------------------------------
# Resend  - booking email delivery
# ---------------------------------------------------------------------------
# 1. Sign up at https://resend.com (free tier covers 3,000 emails/month).
# 2. Verify the email addresses you want bookings delivered to (Settings →
#    Verified Emails). Verify both adamissac08@gmail.com and
#    alanmozhoor@gmail.com.
# 3. Create an API key (API Keys → Create API Key). Copy it below.
RESEND_API_KEY=

# ---------------------------------------------------------------------------
# Booking destination
# ---------------------------------------------------------------------------
# Where booking emails are delivered. Defaults to both tutor inboxes if
# unset. Comma-separate for multiple recipients.
BOOKING_RECIPIENT_EMAIL=adamissac08@gmail.com,alanmozhoor@gmail.com

# ---------------------------------------------------------------------------
# Sender identity
# ---------------------------------------------------------------------------
# On the free tier you can send FROM `onboarding@resend.dev` (it can only
# reach your verified Resend email  - which is fine here, since we always
# send to Adam's own inbox).
#
# Once you verify a custom domain in Resend, switch this to something like:
#   "Adam's Alphabet <booking@adamsalphabet.com>"
BOOKING_FROM_EMAIL="Adam's Alphabet <onboarding@resend.dev>"

# ===========================================================================
# Firebase Authentication
# ---------------------------------------------------------------------------
# Used for the /login, /signup, /forgot-password, and /dashboard pages.
#
# 1. Go to https://console.firebase.google.com and create a new project.
# 2. Build → Authentication → Get started.
#       Sign-in method tab → enable "Email/Password".
#       Sign-in method tab → enable "Google" (set support email).
# 3. (Optional) Build → Firestore Database → Create database (Production
#       mode). Add the rules from the README. Used to persist user
#       profiles; if you skip it, auth still works.
# 4. Project settings (gear icon) → General → Your apps → Web (</>).
#       Register an app, then copy the firebaseConfig values into the
#       variables below. These are PUBLIC by design  - the Firebase web
#       SDK requires them in the browser bundle.
# ===========================================================================
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Set to "false" to enable /login and /signup while testing Firebase locally.
NEXT_PUBLIC_AUTH_COMING_SOON=true
